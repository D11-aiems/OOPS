package looping;

public class looping {

	public static void main(String [] args) {
		System.out.println("code for do while loop");
		int i=20;
		do {
			System.out.println(i);
			i+=i=1;
		}while(i<20);
		System.out.println("code for loop");
		for(int j=5;j<=10;j++)
			System.out.println(j);
		System.out.println("code for each loop");
		int s [] = {8,19,25,30,40};
		for (int k:s) {
			System.out.println(k);
		}
	}
}
